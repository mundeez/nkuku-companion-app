// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── AUTH / RBAC ──────────────────────────
model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          Role     @default(viewer)
  name          String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdSuppliers   Supplier[]        @relation("SupplierCreatedBy")
  createdBatches     Batch[]           @relation("BatchCreatedBy")
  createdCycles      ProductionCycle[] @relation("CycleCreatedBy")
  createdFlocks      BroilerFlock[]    @relation("FlockCreatedBy")
  monthlyOverheads   MonthlyOverhead[]

  @@map("users")
}

enum Role {
  owner
  manager
  viewer
}

// ── SUPPLIERS ────────────────────────────
model Supplier {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @unique @db.VarChar(100)
  description   String?   @db.Text
  chickenType   String?   @map("chicken_type") @db.VarChar(50)
  contact       String?   @db.VarChar(100)
  isActive      Boolean   @default(true) @map("is_active")
  isDefault     Boolean   @default(false) @map("is_default")
  createdBy     String?   @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  feedStages    FeedStage[]
  feedRecords   FeedRecord[]
  flocks        BroilerFlock[]
  batches       Batch[]
  projections   Projection[]
  creator       User?     @relation("SupplierCreatedBy", fields: [createdBy], references: [id])

  @@map("suppliers")
}

// ── FEED STAGES ──────────────────────────
model FeedStage {
  id                String      @id @default(uuid()) @db.Uuid
  supplierId        String      @map("supplier_id") @db.Uuid
  stageName         String      @map("stage_name") @db.VarChar(50)
  stageType         StageType   @default(feed) @map("stage_type")
  dayRangeStart     Int?        @map("day_range_start")
  dayRangeEnd       Int?        @map("day_range_end")
  unitSizeKg        Decimal     @map("unit_size_kg") @db.Decimal(10, 3)
  unitPriceZmw      Decimal     @map("unit_price_zmw") @db.Decimal(12, 2)
  intakePerBirdKg   Decimal     @map("intake_per_bird_kg") @db.Decimal(8, 4)
  sortOrder         Int         @default(0) @map("sort_order")
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  supplier          Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  batchExpenses     BatchExpense[]

  @@unique([supplierId, stageName])
  @@index([supplierId, sortOrder])
  @@map("feed_stages")
}

enum StageType {
  feed
  chick
  medication
  other
}

// ── SUPPLIER CATEGORY TEMPLATES ──────────
model SupplierCategoryTemplate {
  id          String    @id @default(uuid()) @db.Uuid
  category    String    @db.VarChar(50)
  name        String    @db.VarChar(100)
  description String?   @db.Text
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  items       SupplierCategoryTemplateItem[]

  @@unique([category])
  @@index([sortOrder])
  @@map("supplier_category_templates")
}

model SupplierCategoryTemplateItem {
  id             String   @id @default(uuid()) @db.Uuid
  templateId     String   @map("template_id") @db.Uuid
  itemName       String   @map("item_name") @db.VarChar(50)
  itemType       StageType @default(feed) @map("item_type")
  sortOrder      Int      @default(0) @map("sort_order")
  defaultFields  Json?    @map("default_fields")
  isRequired     Boolean  @default(true) @map("is_required")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  template       SupplierCategoryTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, itemName])
  @@index([templateId, sortOrder])
  @@map("supplier_category_template_items")
}

// ── PRODUCTION CYCLES ────────────────────
model ProductionCycle {
  id           String        @id @default(uuid()) @db.Uuid
  cycleNumber  Int           @unique @map("cycle_number")
  label        String?       @db.VarChar(50)
  notes        String?       @db.Text
  status       CycleStatus   @default(planned)
  createdBy    String?       @map("created_by") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  batches      Batch[]
  creator      User?         @relation("CycleCreatedBy", fields: [createdBy], references: [id])

  @@map("production_cycles")
}

enum CycleStatus {
  planned
  active
  completed
}

// ── BATCHES (SHOOTS) ─────────────────────
model Batch {
  id                   String       @id @default(uuid()) @db.Uuid
  cycleId              String       @map("cycle_id") @db.Uuid
  supplierId           String       @map("supplier_id") @db.Uuid
  shootLabel           String       @map("shoot_label") @db.VarChar(20)
  targetExecutionDt    DateTime     @map("target_execution_dt") @db.Date
  salesDate            DateTime     @map("sales_date") @db.Date
  growthQtyAdded       Int          @default(0) @map("growth_qty_added")
  totalQtyAtHand       Int          @map("total_qty_at_hand")
  revenueTargetZmw     Decimal?     @map("revenue_target_zmw") @db.Decimal(14, 2)
  salesPricePerBird    Decimal?     @map("sales_price_per_bird") @db.Decimal(10, 2)
  actualBirdsSold      Int?         @map("actual_birds_sold")
  actualSalePrice      Decimal?     @map("actual_sale_price") @db.Decimal(10, 2)
  mortalityPctAssumed  Decimal      @default(0.0500) @map("mortality_pct_assumed") @db.Decimal(5, 4)
  status               BatchStatus  @default(planned)
  createdBy            String?      @map("created_by") @db.Uuid
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  cycle                ProductionCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  supplier             Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  expenses             BatchExpense[]
  overheadCosts        OverheadCost[]
  mortalityRecords     MortalityRecord[]
  projections          Projection[]
  creator              User?           @relation("BatchCreatedBy", fields: [createdBy], references: [id])

  @@index([cycleId, shootLabel])
  @@map("batches")
}

enum BatchStatus {
  planned
  active
  harvested
  closed
}

// ── BATCH EXPENSES ───────────────────────
model BatchExpense {
  id                 String          @id @default(uuid()) @db.Uuid
  batchId            String          @map("batch_id") @db.Uuid
  feedStageId        String?         @map("feed_stage_id") @db.Uuid
  expenseCategory    ExpenseCategory @default(feed) @map("expense_category")
  description        String?         @db.VarChar(200)
  quantityItems      Decimal?        @map("quantity_items") @db.Decimal(12, 4)
  quantityRoundedUp  Int?            @map("quantity_rounded_up")
  unitPriceZmw       Decimal         @map("unit_price_zmw") @db.Decimal(12, 2)
  subtotalZmw        Decimal         @map("subtotal_zmw") @db.Decimal(14, 2)
  isProjected        Boolean         @default(true) @map("is_projected")
  recordedAt         DateTime        @default(now()) @map("recorded_at") @db.Timestamptz(6)

  batch              Batch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  feedStage          FeedStage?      @relation(fields: [feedStageId], references: [id])

  @@index([batchId])
  @@map("batch_expenses")
}

enum ExpenseCategory {
  feed
  chick
  medication
  labor
  utilities
  transport
  other
}

// ── OVERHEAD COSTS ───────────────────────
model OverheadCost {
  id           String            @id @default(uuid()) @db.Uuid
  batchId      String            @map("batch_id") @db.Uuid
  category     OverheadCategory
  description  String?           @db.VarChar(200)
  amountZmw    Decimal           @map("amount_zmw") @db.Decimal(14, 2)
  isProjected  Boolean           @default(true) @map("is_projected")
  notes        String?           @db.Text
  recordedAt   DateTime          @default(now()) @map("recorded_at") @db.Timestamptz(6)

  batch        Batch             @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("overhead_costs")
}

enum OverheadCategory {
  medication
  vaccination
  labour
  electricity
  water
  litter
  transport_to_market
  other
}

// ── MORTALITY RECORDS ────────────────────
model MortalityRecord {
  id          String   @id @default(uuid()) @db.Uuid
  batchId     String   @map("batch_id") @db.Uuid
  recordedAt  DateTime @map("recorded_at") @db.Timestamptz(6)
  dayOfCycle  Int?     @map("day_of_cycle")
  birdsLost   Int      @default(0) @map("birds_lost")
  cause       String?  @db.VarChar(100)
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, recordedAt])
  @@map("mortality_records")
}

// ── PROJECTIONS ──────────────────────────
model Projection {
  id                 String   @id @default(uuid()) @db.Uuid
  batchId            String   @map("batch_id") @db.Uuid
  supplierId         String   @map("supplier_id") @db.Uuid
  birdCount          Int      @map("bird_count")
  salesPricePerBird  Decimal  @map("sales_price_per_bird") @db.Decimal(10, 2)
  mortalityPct       Decimal  @default(0.0500) @map("mortality_pct") @db.Decimal(5, 4)
  effectiveBirdCount Decimal  @map("effective_bird_count") @db.Decimal(12, 2)
  totalFeedCost      Decimal  @map("total_feed_cost") @db.Decimal(14, 2)
  totalChickCost     Decimal  @map("total_chick_cost") @db.Decimal(14, 2)
  totalOverheadCost  Decimal? @map("total_overhead_cost") @db.Decimal(14, 2)
  totalExpenses      Decimal  @map("total_expenses") @db.Decimal(14, 2)
  projectedRevenue   Decimal  @map("projected_revenue") @db.Decimal(14, 2)
  grossProfit        Decimal  @map("gross_profit") @db.Decimal(14, 2)
  netProfit          Decimal  @map("net_profit") @db.Decimal(14, 2)
  calculatedAt       DateTime @default(now()) @map("calculated_at") @db.Timestamptz(6)

  batch              Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  supplier           Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  @@index([batchId])
  @@map("projections")
}

// ── EXCHANGE RATES ───────────────────────
model ExchangeRate {
  id             String   @id @default(uuid()) @db.Uuid
  currencyFrom   String   @default("USD") @map("currency_from") @db.Char(3)
  currencyTo     String   @default("ZMW") @map("currency_to") @db.Char(3)
  rate           Decimal  @db.Decimal(12, 6)
  effectiveDate  DateTime @map("effective_date") @db.Date
  source         String?  @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([currencyFrom, currencyTo, effectiveDate])
  @@map("exchange_rates")
}

// ── EQUIPMENT ITEMS ──────────────────────
model EquipmentItem {
  id              String              @id @default(uuid()) @db.Uuid
  category        EquipmentCategory
  name            String              @db.VarChar(200)
  unitCostUsd     Decimal?            @map("unit_cost_usd") @db.Decimal(14, 2)
  quantity        Int                 @default(1)
  isCompulsory    Boolean             @default(false) @map("is_compulsory")
  usefulLifeYears Int?                @map("useful_life_years")
  notes           String?             @db.Text
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("equipment_items")
}

enum EquipmentCategory {
  raising_equipment
  abattoir
  cold_storage
  building
  other
}

// ── BROILER MANAGEMENT MODULE ────────────────────

model Breed {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  supplier    String   @db.VarChar(100)
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  performanceTargets PerformanceTarget[]
  flocks             BroilerFlock[]

  @@map("breeds")
}

model PerformanceTarget {
  id            String   @id @default(uuid()) @db.Uuid
  breedId       String   @map("breed_id") @db.Uuid
  ageDays       Int      @map("age_days")
  targetWeight  Decimal  @map("target_weight") @db.Decimal(10, 3)
  targetFeed    Decimal  @map("target_feed") @db.Decimal(10, 3)
  targetFcr     Decimal  @map("target_fcr") @db.Decimal(5, 3)
  targetWater   Decimal? @map("target_water") @db.Decimal(10, 3)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  breed        Breed    @relation(fields: [breedId], references: [id], onDelete: Cascade)

  @@unique([breedId, ageDays])
  @@index([breedId, ageDays])
  @@map("performance_targets")
}

model BroilerFlock {
  id           String      @id @default(uuid()) @db.Uuid
  name         String      @db.VarChar(100)
  breedId      String      @map("breed_id") @db.Uuid
  supplierId   String?     @map("supplier_id") @db.Uuid
  startDate    DateTime    @map("start_date") @db.Date
  initialCount Int         @map("initial_count")
  currentCount Int         @map("current_count")
  targetWeight Decimal?    @map("target_weight") @db.Decimal(10, 3)
  targetAge    Int?        @map("target_age")
  feedTransitionDay Int?   @map("feed_transition_day")
  chickPriceZmw Decimal?  @map("chick_price_zmw") @db.Decimal(14, 2)
  chicksCollected Boolean  @default(false) @map("chicks_collected")
  collectionDate  DateTime? @map("collection_date") @db.Date
  chickQualityNotes String?  @map("chick_quality_notes") @db.VarChar(500)
  salePriceZmw    Decimal?    @map("sale_price_zmw") @db.Decimal(14, 2)
  soldDate        DateTime?   @map("sold_date") @db.Date
  status       FlockStatus @default(active)
  createdBy    String?     @map("created_by") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  breed              Breed                @relation(fields: [breedId], references: [id])
  supplier           Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  creator            User?                @relation("FlockCreatedBy", fields: [createdBy], references: [id])
  growthRecords      GrowthRecord[]
  feedRecords        FeedRecord[]
  waterRecords       WaterRecord[]
  mortalityEvents    MortalityEvent[]
  vaccinationEvents  VaccinationEvent[]
  medicationRecords  MedicationRecord[]
  environmentalRecords EnvironmentalRecord[]
  flockTasks         FlockTask[]
  financialRecords   FinancialRecord[]
  alerts             Alert[]

  @@index([breedId, status])
  @@index([supplierId])
  @@map("broiler_flocks")
}

enum FlockStatus {
  active
  sold
  completed
  cancelled
}

model GrowthRecord {
  id         String   @id @default(uuid()) @db.Uuid
  flockId    String   @map("flock_id") @db.Uuid
  recordDate DateTime @map("record_date") @db.Date
  sampleSize Int      @map("sample_size")
  avgWeight  Decimal  @map("avg_weight") @db.Decimal(10, 3)
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  flock      BroilerFlock @relation(fields: [flockId], references: [id], onDelete: Cascade)

  @@index([flockId, recordDate])
  @@map("growth_records")
}

model FeedRecord {
  id         String   @id @default(uuid()) @db.Uuid
  flockId    String   @map("flock_id") @db.Uuid
  supplierId String?  @map("supplier_id") @db.Uuid   // NEW
  recordDate DateTime @map("record_date") @db.Date
  feedType   String   @db.VarChar(50)
  feedBrand  String?  @map("feed_brand") @db.VarChar(100)
  quantityKg Decimal  @map("quantity_kg") @db.Decimal(10, 3)
  costZmw    Decimal? @map("cost_zmw") @db.Decimal(14, 2)
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  flock      BroilerFlock @relation(fields: [flockId], references: [id], onDelete: Cascade)
  supplier   Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)  // NEW

  @@index([flockId, recordDate])
  @@map("feed_records")
}

model WaterRecord {
  id             String   @id @default(uuid()) @db.Uuid
  flockId        String   @map("flock_id") @db.Uuid
  recordDate     DateTime @map("record_date") @db.Date
  quantityLiters Decimal  @map("quantity_liters") @db.Decimal(10, 2)
  ph             Decimal? @db.Decimal(4, 2)
  temperature    Decimal? @map("temperature_c") @db.Decimal(5, 2)
  costZmw        Decimal? @map("cost_zmw") @db.Decimal(14, 2)
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  flock          BroilerFlock @relation(fields: [flockId], references: [id], onDelete: Cascade)

  @@index([flockId, recordDate])
  @@map("water_records")
}

model MortalityEvent {
  id        String   @id @default(uuid()) @db.Uuid
  flockId   String   @map("flock_id") @db.Uuid
  eventDate DateTime @map("event_date") @db.Date
  count     Int
  cause     String?  @db.VarChar(200)
  ageDays   Int?     @map("age_days")
  costZmw   Decimal? @map("cost_zmw") @db.Decimal(14, 2)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  flock     BroilerFlock @relation(fields: [flockId], references: [id], onDelete: Cascade)

  @@index([flockId, eventDate])
  @@map("mortality_events")
}

model VaccinationEvent {
  id                String   @id @default(uuid()) @db.Uuid
  flockId           String   @map("flock_id") @db.Uuid
  vaccineName       String   @map("vaccine_name") @db.VarChar(100)
  vaccineType       String   @map("vaccine_type") @db.VarChar(100)
  adminDate         DateTime @map("admin_date") @db.Date
  adminMethod       String   @map("admin_method") @db.VarChar(50)
  ageDays           Int      @map("age_days")
  costZmw           Decimal? @map("cost_zmw") @db.Decimal(14, 2)
  nextDueDate       DateTime? @map("next_due_date") @db.Date
  batchNumber       String?  @map("batch_number") @db.VarChar(100)
  expiryDate        DateTime? @map("expiry_date") @db.Date
  vaccineInventoryId String?  @map("vaccine_inventory_id") @db.Uuid
  notes             String?  @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  flock             BroilerFlock @relation(fields: [flockId], references: [id], onDelete: Cascade)
  vaccineInventory  VaccineInventory? @relation(fields: [vaccineInventoryId], references: [id], onDelete: SetNull)

  @@index([flockId, adminDate])
  @@map("vaccination_events")
}

model FinancialRecord {
  id                String              @id @default(uuid()) @db.Uuid
  flockId           String              @map("flock_id") @db.Uuid
  sourceRecordId    String?             @map("source_record_id") @db.Uuid
  sourceTable       String?             @map("source_table") @db.VarChar(50)
  recordDate        DateTime            @map("record_date") @db.Date
  category          FinancialCategory
  description       String              @db.VarChar(200)
  amountZmw         Decimal             @map("amount_zmw") @db.Decimal(14, 2)
  isIncome          Boolean             @default(false) @map("is_income")
  isSystemGenerated Boolean             @default(false) @map("is_system_generated")
  isProjection      Boolean             @default(false) @map("is_projection")
  notes             String?             @db.Text
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  flock             BroilerFlock        @relation(fields: [flockId], references: [id], onDelete: Cascade)

  @@index([flockId, recordDate])
  @@index([sourceRecordId])
  @@index([isSystemGenerated])
  @@map("financial_records")
}

enum FinancialCategory {
  chick_purchase
  feed
  vaccines
  medication
  labor
  utilities
  equipment
  sales
  other
}

model Alert {
  id         String        @id @default(uuid()) @db.Uuid
  flockId    String        @map("flock_id") @db.Uuid
  alertType  AlertType     @map("alert_type")
  title      String        @db.VarChar(200)
  message    String        @db.Text
  severity   AlertSeverity @default(info)
  dueDate    DateTime      @map("due_date") @db.Date
  isRead     Boolean       @default(false) @map("is_read")
  isResolved Boolean       @default(false) @map("is_resolved")
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  flock      BroilerFlock  @relation(fields: [flockId], references: [id], onDelete: Cascade)

  @@index([flockId, isResolved, dueDate])
  @@map("alerts")
}

enum AlertType {
  temperature_adjustment
  vaccination_due
  feed_transition
  weight_check
  mortality_threshold
  environmental
  financial
  medication_due
  withdrawal_due
  vaccine_expiry
  environmental_threshold
  task_due
}

enum AlertSeverity {
  info
  warning
  critical
}

model Disease {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @unique @db.VarChar(100)
  category          String   @db.VarChar(50)
  incubation        String?  @db.VarChar(100)
  mortalityRate     String?  @map("mortality_rate") @db.VarChar(50)
  symptoms          String?  @db.Text
  prevention        String?  @db.Text
  treatment         String?  @db.Text
  organicTreatments String?  @map("organic_treatments") @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("diseases")
}

model VaccinationSchedule {
  id          String   @id @default(uuid()) @db.Uuid
  breedId     String?  @map("breed_id") @db.Uuid
  name        String   @db.VarChar(100)
  isDefault   Boolean  @default(false) @map("is_default")
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  items       VaccinationScheduleItem[]

  @@unique([name])
  @@map("vaccination_schedules")
}

model VaccinationScheduleItem {
  id          String   @id @default(uuid()) @db.Uuid
  scheduleId  String   @map("schedule_id") @db.Uuid
  vaccineName String   @map("vaccine_name") @db.VarChar(100)
  vaccineType String   @map("vaccine_type") @db.VarChar(100)
  ageDays     Int      @map("age_days")
  adminMethod String   @map("admin_method") @db.VarChar(50)
  sortOrder   Int      @map("sort_order")
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  schedule    VaccinationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, sortOrder])
  @@map("vaccination_schedule_items")
}

// ── MEDICATION & VACCINE MANAGEMENT ───────

enum MedicationCategory {
  antibiotic
  coccidiostat
  electrolyte
  vitamin
  probiotic
  acidifier
  phytogenic
  other
}

model MedicationRecord {
  id              String   @id @default(uuid()) @db.Uuid
  flockId         String   @map("flock_id") @db.Uuid
  recordDate      DateTime @map("record_date") @db.Date
  productName     String   @map("product_name") @db.VarChar(100)
  category        MedicationCategory
  dose            String?  @db.VarChar(100)
  route           String?  @db.VarChar(50)
  startDate       DateTime @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  withdrawalDays  Int?     @map("withdrawal_days")
  withdrawalDate  DateTime? @map("withdrawal_date") @db.Date
  costZmw         Decimal? @map("cost_zmw") @db.Decimal(14, 2)
  veterinarian    String?  @db.VarChar(100)
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  flock           BroilerFlock @relation(fields: [flockId], references: [id], onDelete: Cascade)

  @@index([flockId, recordDate])
  @@map("medication_records")
}

enum VaccineInventoryStatus {
  available
  in_use
  expired
  depleted
}

model VaccineInventory {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(100)
  disease       String?  @db.VarChar(100)
  supplier      String?  @db.VarChar(100)
  batchNumber   String   @map("batch_number") @db.VarChar(100)
  quantityDoses Int      @map("quantity_doses")
  expiryDate    DateTime @map("expiry_date") @db.Date
  status        VaccineInventoryStatus @default(available)
  costZmw       Decimal? @map("cost_zmw") @db.Decimal(14, 2)
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  vaccinationEvents VaccinationEvent[]

  @@map("vaccine_inventory")
}

model EnvironmentalRecord {
  id              String   @id @default(uuid()) @db.Uuid
  flockId         String   @map("flock_id") @db.Uuid
  recordDate      DateTime @map("record_date") @db.Date
  timeOfDay       String?  @map("time_of_day") @db.VarChar(20)
  temperatureC    Decimal? @map("temperature_c") @db.Decimal(5, 2)
  humidityPct     Decimal? @map("humidity_pct") @db.Decimal(5, 2)
  ammoniaPpm      Decimal? @map("ammonia_ppm") @db.Decimal(5, 2)
  lightHours      Decimal? @map("light_hours") @db.Decimal(4, 2)
  litterScore     Int?     @map("litter_score")
  ventilationNote String?  @map("ventilation_note") @db.Text
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  flock           BroilerFlock @relation(fields: [flockId], references: [id], onDelete: Cascade)

  @@index([flockId, recordDate])
  @@map("environmental_records")
}

enum FlockTaskCategory {
  vaccination
  feed
  water
  environment
  health
  biosecurity
  management
}

model FlockTask {
  id          String      @id @default(uuid()) @db.Uuid
  flockId     String      @map("flock_id") @db.Uuid
  taskDate    DateTime    @map("task_date") @db.Date
  ageDays     Int         @map("age_days")
  category    FlockTaskCategory
  title       String      @db.VarChar(200)
  description String?     @db.Text
  isCompleted Boolean     @default(false) @map("is_completed")
  isSkipped   Boolean     @default(false) @map("is_skipped")
  completedAt DateTime?   @map("completed_at") @db.Timestamptz(6)
  notes       String?     @db.Text
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  flock       BroilerFlock @relation(fields: [flockId], references: [id], onDelete: Cascade)

  @@index([flockId, taskDate])
  @@map("flock_tasks")
}

// ── FINANCIAL PERIODS ────────────────────
model FinancialPeriod {
  id         String     @id @default(uuid()) @db.Uuid
  label      String     @db.VarChar(20)
  periodType PeriodType @map("period_type")
  startDate  DateTime   @map("start_date") @db.Date
  endDate    DateTime   @map("end_date") @db.Date
  isClosed   Boolean    @default(false) @map("is_closed")
  closedAt   DateTime?  @map("closed_at") @db.Timestamptz(6)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  auditLogs AuditLog[]

  @@unique([label, periodType])
  @@index([startDate, endDate])
  @@map("financial_periods")
}

enum PeriodType {
  monthly
  quarterly
  annual
}

// ── AUDIT LOG ────────────────────────────
model AuditLog {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String?     @map("user_id") @db.Uuid
  entityType    String      @map("entity_type") @db.VarChar(50)
  entityId      String      @map("entity_id") @db.Uuid
  action        AuditAction
  previousState Json?       @map("previous_state")
  newState      Json?       @map("new_state")
  ipAddress     String?     @map("ip_address") @db.VarChar(45)
  periodId      String?     @map("period_id") @db.Uuid
  occurredAt    DateTime    @default(now()) @map("occurred_at") @db.Timestamptz(6)

  period FinancialPeriod? @relation(fields: [periodId], references: [id])

  @@index([entityType, entityId])
  @@index([userId, occurredAt])
  @@map("audit_logs")
}

enum AuditAction {
  create
  update
  delete
  period_close
  report_generate
}

// ── SCHEDULED REPORTS ────────────────────
model ScheduledReport {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @db.VarChar(100)
  reportType  ReportType       @map("report_type")
  frequency   ReportFrequency
  scope       ReportScope
  scopeId     String?          @map("scope_id") @db.Uuid
  recipients  Json
  format      ExportFormat
  isActive    Boolean          @default(true) @map("is_active")
  lastRunAt   DateTime?        @map("last_run_at") @db.Timestamptz(6)
  nextRunAt   DateTime?        @map("next_run_at") @db.Timestamptz(6)
  createdBy   String           @map("created_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  executions ReportExecution[]

  @@map("scheduled_reports")
}

model ReportExecution {
  id               String            @id @default(uuid()) @db.Uuid
  scheduledReportId String           @map("scheduled_report_id") @db.Uuid
  status           ExecutionStatus
  fileUrl          String?           @db.VarChar(500)
  errorMessage     String?           @map("error_message") @db.Text
  executedAt       DateTime          @default(now()) @map("executed_at") @db.Timestamptz(6)

  scheduledReport ScheduledReport @relation(fields: [scheduledReportId], references: [id], onDelete: Cascade)

  @@index([scheduledReportId, executedAt])
  @@map("report_executions")
}

enum ReportType {
  income_statement
  balance_sheet
  cash_flow
  cost_breakdown
  flock_profitability
  cycle_summary
}

enum ReportFrequency {
  weekly
  monthly
  quarterly
}

enum ReportScope {
  global
  flock
  cycle
}

enum ExportFormat {
  pdf
  csv
  excel
}

enum ExecutionStatus {
  success
  failed
  running
}

// ── MONTHLY OVERHEADS ────────────────────
model MonthlyOverhead {
  id           String           @id @default(uuid()) @db.Uuid
  yearMonth    String           @map("year_month") @db.VarChar(7)
  category     OverheadCategory @map("category")
  description  String?          @db.VarChar(200)
  amountZmw    Decimal          @map("amount_zmw") @db.Decimal(14, 2)
  contractType String           @map("contract_type") @db.VarChar(20)
  recordedAt   DateTime         @default(now()) @map("recorded_at") @db.Timestamptz(6)
  createdBy    String           @map("created_by") @db.Uuid

  user         User             @relation(fields: [createdBy], references: [id])

  @@unique([yearMonth, category, description])
  @@map("monthly_overheads")
}

// ── FLOCK OVERHEAD ALLOCATIONS ───────────
model FlockOverheadAllocation {
  id                   String   @id @default(uuid()) @db.Uuid
  monthlyOverheadId    String   @map("monthly_overhead_id") @db.Uuid
  flockId              String   @map("flock_id") @db.Uuid
  allocationDate       DateTime @map("allocation_date") @db.Date
  daysActiveInMonth    Int      @map("days_active_in_month")
  totalActiveFlockDays Int      @map("total_active_flock_days")
  allocatedAmount      Decimal  @map("allocated_amount") @db.Decimal(14, 2)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([flockId, allocationDate])
  @@map("flock_overhead_allocations")
}
