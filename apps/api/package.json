{
  "name": "api",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "Nkuku Companion API \u2014 Fastify + Prisma + PostgreSQL",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx src/db/seeds/main.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^2.1.0",
    "@prisma/client": "^5.8.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.25.0",
    "fastify-type-provider-zod": "^1.1.9",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.4",
    "decimal.js": "^10.4.3",
    "pdfkit": "^0.15.0",
    "exceljs": "^4.4.0",
    "csv-stringify": "^6.4.6",
    "nodemailer": "^6.9.9",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "prisma": "^5.8.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "@types/pdfkit": "^0.13.4",
    "@types/nodemailer": "^6.4.14",
    "@types/node-cron": "^3.0.11"
  },
  "prisma": {
    "seed": "tsx src/db/seeds/main.ts"
  },
  "type": "module"
}
