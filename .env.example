# ============================================================
# Nkuku Companion — Production Environment Variables
# Copy to .env and fill in real values before deployment
# ============================================================

# ── Database ───────────────────────────────
# Must be a strong password (min 32 chars recommended)
DB_PASSWORD=your_strong_postgres_password_here

# Full connection string (uses DB_PASSWORD above)
DATABASE_URL=postgresql://nkuku_user:your_strong_postgres_password_here@postgres:5432/nkuku_db

# ── Redis ──────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT Secrets ────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_min_64_chars_change_me_immediately
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Default Owner Account ──────────────────
OWNER_EMAIL=owner@nkuku.local
OWNER_PASSWORD=change_me_immediately_after_first_login

# ── CORS ───────────────────────────────────
# Comma-separated list of allowed origins
# Include your domain, the mobile app origin (if any), and localhost for dev
CORS_ORIGINS=https://nkuku.deeztechnology.solutions

# ── Mobile App API URL ─────────────────────
# Used in Flutter lib/services/api_service.dart
# In production the mobile app should call:
#   https://nkuku.deeztechnology.solutions/api/v1
# Update this in apps/mobile/lib/services/api_service.dart before building APK
